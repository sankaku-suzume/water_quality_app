.container
  .result_header
    %h1.result_title 検査結果
    = render 'status_wrapper', result: @result

  %h2.result_subtitle #{@result.sample.plant.name} #{@result.sample.sampling_date} ＜#{@result.test_item.name}: #{@result.value}#{@result.test_item.unit}＞
  .result_recent_results
    %h3.result-recent_results_title 直近20検体の結果
    .result-recent_results_table-wrapper
      %table.result-recent_results_table
        %tr
          %th 採水日
          %th 測定値 (#{@result.test_item.unit})
        - @recent_results.each do |result|
          %tr
            %td= result.sample.sampling_date
            %td= result.value
      %table.result-recent_min-max-table
        %tr
          %th 平均値
          %td= average(@recent_results)
        %tr
          %th 最小値
          %td= minimum(@recent_results)
        %tr
          %th 最大値
          %td= maximum(@recent_results)
  .result_chart
    %canvas{ data: { controller: "chartjs", chartjs: { data: { value: @chart_data.to_json }, options: { value: @chart_options.to_json } } } }

  %h2.result_approval-title 承認履歴
  = turbo_frame_tag 'approvals-list' do
    .result_approvals#approvals
      - @result.approvals.each do |approval|
        = render 'approval', approval: approval
      - unless @result.approvals.any?
        %p#no_approval_text 承認履歴はまだありません

  .div-comment
    %p 直近20検体の結果について、平均・最大・最小値を表示します。
    %p グラフで表示します。
